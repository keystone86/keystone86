.entry ENTRY_INT, 0x0E

; Rung 5 Pass 2 bounded real-mode INT_ENTER path.
; FETCH_IMM8 captures the vector in T4. INT_ENTER performs only the bounded
; IVT/frame staging primitive; ENDI CM_INT remains the architectural boundary
; for EIP/CS/FLAGS/ESP and stack-frame visibility.
ENTRY_INT:
    SVCW FETCH_IMM8
    BR C_FAULT, SUB_FAULT_HANDLER
    SVCW INT_ENTER
    BR C_FAULT, SUB_FAULT_HANDLER
    ENDI CM_INT
